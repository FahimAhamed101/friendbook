<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainChatLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/layoutcolor"
    android:orientation="vertical">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="?attr/layoutcolor"
        android:elevation="2dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/chatThreadBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_back"
                app:tint="?attr/texttwocolor" />

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/chatThreadAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginStart="14dp"
                android:src="@drawable/avatar" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chatThreadTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bold_roboto"
                        android:textColor="?attr/textcolor"
                        android:textSize="14sp"
                        tools:text="User Name" />

                    <ImageView
                        android:id="@+id/chatThreadVerifyIcon"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_verify"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chatThreadStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bold_roboto"
                        android:textColor="?attr/texttwocolor"
                        android:textSize="12sp"
                        tools:text="Online" />

                    <ImageView
                        android:id="@+id/chatThreadOnlineIndicator"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="6dp"
                        android:layout_marginTop="2dp"
                        android:src="@drawable/circle"
                        android:visibility="gone"
                        app:tint="#4CAF50" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/chatThreadAudioCall"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:padding="3dp"
                android:src="@drawable/ic_audio_call"
                app:tint="@color/colorPrimary" />

            <ImageView
                android:id="@+id/chatThreadVideoCall"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:layout_marginStart="16dp"
                android:padding="3dp"
                android:src="@drawable/ic_video_call"
                app:tint="@color/colorPrimary" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/chatThreadProgressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="#1877F2"
        app:trackColor="#FF7CB6FF"
        app:trackCornerRadius="2dp"
        app:trackThickness="2dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatThreadRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp" />

        <TextView
            android:id="@+id/chatThreadEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:alpha="0.5"
            android:fontFamily="@font/bold"
            android:text="@string/nothing_found"
            android:textColor="?attr/texttwocolor"
            android:textSize="20sp"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Typing Indicator -->
    <LinearLayout
        android:id="@+id/chatThreadTypingLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone">
        <include layout="@layout/typing" />
    </LinearLayout>

    <!-- Input Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="?attr/layoutcolor"
        android:elevation="8dp">

        <ImageView
            android:id="@+id/chatThreadAddMedia"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/circle"
            android:backgroundTint="?attr/backgroundcolor"
            android:padding="7dp"
            android:src="@drawable/ic_plus"
            app:tint="#596C84" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="35dp"
            android:layout_gravity="center"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/btn_round"
            android:backgroundTint="?attr/backgroundcolor"
            android:orientation="horizontal">

            <com.hendraanggrian.appcompat.widget.SocialEditText
                android:id="@+id/chatThreadInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@null"
                android:fontFamily="@font/bold_roboto"
                android:hint="@string/send_a_message"
                android:inputType="textShortMessage|textAutoCorrect|textCapSentences"
                android:maxLines="4"
                android:textColor="?attr/textcolor"
                android:textColorHint="?attr/texttwocolor"
                android:textSize="14sp"
                app:hashtagColor="@color/colorPrimary"
                app:mentionColor="@color/colorPrimary"
                app:socialFlags="hashtag|mention" />
        </LinearLayout>

        <ImageView
            android:id="@+id/chatThreadSend"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:padding="5dp"
            android:src="@drawable/ic_send"
            app:tint="@color/colorPrimary" />
    </LinearLayout>

</LinearLayout>
