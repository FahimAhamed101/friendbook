<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/createPostMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/layoutcolor">

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/createPostProgressBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="#1877F2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:trackColor="#FF7CB6FF"
        app:trackCornerRadius="2dp"
        app:trackThickness="2dp" />

    <ImageView
        android:id="@+id/createPostBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/circle"
        android:backgroundTint="?attr/backgroundcolor"
        android:padding="5dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#596C84" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/bold"
        android:text="Create Post"
        android:textColor="@color/colorPrimary"
        android:textSize="22sp"
        app:layout_constraintBottom_toBottomOf="@+id/createPostBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/createPostBack" />

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/createPostAvatar"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/createPostBack" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/createPostAvatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/createPostAvatar"
        app:layout_constraintTop_toTopOf="@+id/createPostAvatar">

        <TextView
            android:id="@+id/createPostAuthorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bold_roboto"
            android:textColor="?attr/textcolor"
            android:textSize="16sp"
            tools:text="User Name" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/createPostPrivacy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bold_roboto"
                android:text="Everyone"
                android:textColor="?attr/texttwocolor"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bold_roboto"
                android:text=" . "
                android:textColor="?attr/texttwocolor"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/createPostLocationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bold_roboto"
                android:text="Add location"
                android:textColor="?attr/texttwocolor"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <EditText
        android:id="@+id/createPostTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:background="@null"
        android:fontFamily="@font/bold"
        android:hint="Add a catchy title..."
        android:textColor="?attr/textcolor"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/createPostAvatar" />

    <com.hendraanggrian.appcompat.widget.SocialEditText
        android:id="@+id/createPostContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="@null"
        android:fontFamily="@font/bold_roboto"
        android:hint="What's on your mind? #hashtag @mention"
        android:minHeight="100dp"
        android:textColor="?attr/textcolor"
        android:textColorHint="?attr/texttwocolor"
        android:textSize="15sp"
        app:hashtagColor="@color/colorPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/createPostTitle"
        app:mentionColor="@color/colorPrimary"
        app:socialFlags="hashtag|mention" />

    <RelativeLayout
        android:id="@+id/createPostMediaPreviewContainer"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/createPostContent">

        <ImageView
            android:id="@+id/createPostImagePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/cover" />

        <ImageView
            android:id="@+id/createPostCancelMedia"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/circle"
            android:backgroundTint="?attr/backgroundcolor"
            android:padding="5dp"
            android:src="@drawable/ic_cancel"
            app:tint="#596C84" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/createPostTools"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:fontFamily="@font/bold_roboto"
            android:gravity="center_vertical"
            android:text="Add to your post"
            android:textColor="?attr/textcolor"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/createPostPickImage"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp"
            android:padding="3dp"
            android:src="@drawable/add_photo" />

        <ImageView
            android:id="@+id/createPostPickVideo"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp"
            android:padding="3dp"
            android:src="@drawable/add_video" />

        <ImageView
            android:id="@+id/createPostFeeling"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="16dp"
            android:padding="4dp"
            android:src="@drawable/add_feeling" />
    </LinearLayout>

    <Button
        android:id="@+id/createPostSubmit"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/btn_round"
        android:backgroundTint="@color/colorPrimary"
        android:fontFamily="@font/bold_roboto"
        android:text="Post"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/createPostTools"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/createPostStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:textColor="#F44336"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/createPostTools"
        app:layout_constraintEnd_toStartOf="@+id/createPostSubmit"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="Error message here" />

</androidx.constraintlayout.widget.ConstraintLayout>
