<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="?attr/layoutcolor">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/conversationAvatar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:src="@drawable/avatar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="10dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/conversationOnlineIndicator"
        app:layout_constraintStart_toEndOf="@+id/conversationAvatar"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/conversationName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="@font/bold_roboto"
                android:textColor="?attr/textcolor"
                android:textSize="18sp"
                tools:text="User Name" />

            <TextView
                android:id="@+id/conversationTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="?attr/texttwocolor"
                android:textSize="12sp"
                tools:text="12:00 PM" />

            <ImageView
                android:id="@+id/conversationVerifyIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:layout_marginStart="8dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/ic_verify"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/conversationSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/texttwocolor"
            android:textSize="14sp"
            tools:text="Subtitle" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/conversationLastMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="@font/bold_roboto"
                android:maxLines="1"
                android:textColor="?attr/texttwocolor"
                android:textSize="16sp"
                tools:text="Last message content..." />

            <TextView
                android:id="@+id/conversationUnread"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/circle"
                android:backgroundTint="@color/colorAccent"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="3" />

        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/conversationOnlineIndicator"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/circle"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#4CAF50" />

</androidx.constraintlayout.widget.ConstraintLayout>
