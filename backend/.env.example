# Backend
# The backend accepts AUTH_PORT or PORT. For Webuzo on a separate API
# subdomain, keep this aligned with the backend app port.
AUTH_PORT=4000
CLIENT_ORIGIN=http://localhost:3000,https://extremis.top,https://www.extremis.top
MONGODB_URI=mongodb+srv://admin:admin@cluster0.7khaz.mongodb.net/extremis_auth
# Optional fallback for local DNS environments where Node cannot resolve mongodb+srv records.
# MONGODB_LOCAL_URI=mongodb://admin:admin@cluster0-shard-00-00.7khaz.mongodb.net:27017,cluster0-shard-00-01.7khaz.mongodb.net:27017,cluster0-shard-00-02.7khaz.mongodb.net:27017/extremis_auth?tls=true&authSource=admin&retryWrites=true&w=majority
MONGODB_DB=extremis
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_TIMEOUT_MS=15000
